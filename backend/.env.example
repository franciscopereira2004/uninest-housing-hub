NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

USE_IN_MEMORY_DB=true
# Set to false to persist data in Azure Cosmos DB.
# When false, COSMOS_ENDPOINT and COSMOS_KEY are required.

COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE_ID=uninest
COSMOS_USERS_CONTAINER=users
COSMOS_LISTINGS_CONTAINER=listings
# For users registration, the users container must use partition key /id.

BLOB_CONNECTION_STRING=
BLOB_AVATARS_CONTAINER=avatars
BLOB_ROOM_IMAGES_CONTAINER=room-images
BLOB_PROPERTY_IMAGES_CONTAINER=property-images
BLOB_USE_MOCK=true
BLOB_MOCK_BASE_URL=https://example.blob.core.windows.net

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
MAX_UPLOAD_SIZE_MB=5
